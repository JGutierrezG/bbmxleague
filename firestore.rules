rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Tournaments ──────────────────────────────────────────────────────────
    match /tournaments/{tournamentId} {

      function tournamentDoc() {
        return get(/databases/$(database)/documents/tournaments/$(tournamentId)).data;
      }

      function isOrganizerOf(t) {
        return request.auth != null && request.auth.uid == t.createdBy;
      }
      function isRefereeOf(t) {
        return request.auth != null &&
               'refereeUids' in t &&
               request.auth.uid in t.refereeUids;
      }
      function canManage(t) {
        return isOrganizerOf(t) || isRefereeOf(t);
      }

      allow read: if request.auth != null;

      allow create: if request.auth != null &&
                       request.resource.data.createdBy == request.auth.uid;

      allow update: if request.auth != null && (
                       canManage(resource.data) ||
                       request.resource.data.diff(resource.data)
                         .affectedKeys().hasOnly(['participantUids'])
                    );

      allow delete: if isOrganizerOf(resource.data);

      // ── Participants ───────────────────────────────────────────────────────
      // Read: any authenticated user (needed to display rosters).
      // Create: organizer/referee adds manually, or a registered user adds
      //         themselves (their uid must match the participant's uid field).
      // Update/Delete: only organizer or referee.
      match /participants/{participantId} {
        allow read:   if request.auth != null;
        allow create: if request.auth != null && (
                         canManage(tournamentDoc()) ||
                         request.resource.data.uid == request.auth.uid
                      );
        allow update: if canManage(tournamentDoc());
        allow delete: if canManage(tournamentDoc());
      }

      // ── Groups ────────────────────────────────────────────────────────────
      match /groups/{groupId} {
        allow read:  if request.auth != null;
        allow write: if canManage(tournamentDoc());

        // Matches: only organizer or referee can score.
        match /matches/{matchId} {
          allow read:  if request.auth != null;
          allow write: if canManage(tournamentDoc());
        }
      }

      // ── Bracket ───────────────────────────────────────────────────────────
      match /bracket/{matchId} {
        allow read:  if request.auth != null;
        allow write: if canManage(tournamentDoc());
      }
    }
  }
}
