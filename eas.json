{
  "cli": {
    "version": ">= 20.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "prebuildCommand": "echo $GOOGLE_SERVICES_JSON_B64 | base64 -d > ./google-services.json"
    }
  },
  "submit": {
    "production": {}
  }
}
